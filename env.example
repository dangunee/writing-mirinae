# Checkout redirects — success URL must match CHECKOUT_REDIRECT_ALLOWLIST prefix (see server/lib/urls.ts).
# Stripe 결제 완료 후: 코스 준비 대기용 페이지로 보낸 뒤 홈으로 이동합니다.
DEFAULT_CHECKOUT_SUCCESS_URL=https://mirinae.jp/writing/app/complete
DEFAULT_CHECKOUT_CANCEL_URL=https://mirinae.jp/writing/
# Comma-separated URL prefixes (e.g. https://mirinae.jp/writing,https://localhost:5173/writing)
CHECKOUT_REDIRECT_ALLOWLIST=https://mirinae.jp/writing,https://localhost:5173/writing
