# Stripe（サーバー — Vercel / ローカル .env に設定。リポジトリにコミットしない）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# フロントのみ（Payment Element 等で使用する場合）。Checkout リダイレクトのみなら未設定可。
VITE_STRIPE_PUBLISHABLE_KEY=

# リダイレクト許可プレフィックス（カンマ区切り）。trial / 既存 checkout の successUrl / cancelUrl がこのプレフィックスで始まる必要あり。
# 例: https://writing-mirinae.vercel.app/writing,http://localhost:5173/writing
CHECKOUT_REDIRECT_ALLOWLIST=

# 省略時はリクエスト body の successUrl / cancelUrl を使用（同一オリジンをクライアントが送る場合は allowlist に含める）
# TRIAL_PAYMENT_SUCCESS_URL=
# TRIAL_PAYMENT_CANCEL_URL=

# API がフロントと別オリジンならフルオリジン（例: https://api.example.com）
# VITE_API_BASE_URL=
