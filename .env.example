# Stripe（サーバー — Vercel / ローカル .env に設定。リポジトリにコミットしない）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# フロントのみ（Payment Element 等で使用する場合）。Checkout リダイレクトのみなら未設定可。
VITE_STRIPE_PUBLISHABLE_KEY=

# リダイレクト許可プレフィックス（カンマ区切り）。trial / 既存 checkout の successUrl / cancelUrl がこのプレフィックスで始まる必要あり。
# 例: https://writing-mirinae.vercel.app/writing,http://localhost:5173/writing
CHECKOUT_REDIRECT_ALLOWLIST=

# 省略時はリクエスト body の successUrl / cancelUrl を使用（同一オリジンをクライアントが送る場合は allowlist に含める）
# TRIAL_PAYMENT_SUCCESS_URL=
# TRIAL_PAYMENT_CANCEL_URL=

# 体験レッスン決済完了メール（Webhook → Resend）。未設定時はメール送信をスキップ（ログのみ）
# RESEND_API_KEY=
# TRIAL_LESSON_ADMIN_EMAIL=you@example.com
# RESEND_FROM_EMAIL=Writing <onboarding@resend.dev>
# SITE_URL=https://writing-mirinae.vercel.app

# 本番ビルド必須: フロント (Vite) と API (Next 等) が別オリジンのとき、API のオリジン（末尾スラッシュなし）
# 例: https://api.example.com  → fetch は https://api.example.com/api/...
# 未設定の本番では同一オリジン /api にはフォールバックしません。設定変更後は再ビルド・再デプロイ。
# VITE_API_BASE_URL=
