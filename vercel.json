{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/bank-transfer-notify.ts": {
      "maxDuration": 30
    },
    "api/webhooks/stripe.ts": {
      "maxDuration": 30
    },
    "api/writing/trial-payment/create-checkout-session.ts": {
      "maxDuration": 30
    },
    "api/writing/trial-payment/payment-result.ts": {
      "maxDuration": 30
    },
    "api/writing/admin/trial-applications/index.ts": {
      "maxDuration": 30
    },
    "api/writing/admin/bff.ts": {
      "maxDuration": 30
    },
    "api/writing/admin/regular-access-grants/[id].ts": {
      "maxDuration": 30
    },
    "api/writing/trial/bff.ts": {
      "maxDuration": 30
    },
    "api/writing/regular/access/consume.ts": {
      "maxDuration": 30
    },
    "api/writing/regular/session/current.ts": {
      "maxDuration": 15
    }
  },
  "redirects": [
    {
      "source": "/writing/trial",
      "destination": "/writing/intro",
      "permanent": true
    },
    {
      "source": "/writing/trial/",
      "destination": "/writing/intro",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/writing/trial/session/current",
      "destination": "/api/writing/trial/bff?op=session_current"
    },
    {
      "source": "/api/writing/trial/access/consume",
      "destination": "/api/writing/trial/bff?op=access_consume"
    },
    {
      "source": "/api/writing/trial/start-link",
      "destination": "/api/writing/trial/bff?op=start_link"
    },
    {
      "source": "/api/writing/trial/reissue-link",
      "destination": "/api/writing/trial/bff?op=reissue_link"
    },
    {
      "source": "/api/writing/admin/trial-applications/:id/extend-access",
      "destination": "/api/writing/admin/bff?__trial_admin_op=extend&id=:id"
    },
    {
      "source": "/api/writing/admin/trial-applications/:id/resend-access",
      "destination": "/api/writing/admin/bff?__trial_admin_op=resend&id=:id"
    },
    {
      "source": "/api/writing/admin/trial-applications/:id/activate",
      "destination": "/api/writing/admin/bff?__trial_admin_op=activate&id=:id"
    },
    {
      "source": "/api/writing/regular/access/dev-seed",
      "destination": "/api/writing/admin/regular-access-grants/dev-seed"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
