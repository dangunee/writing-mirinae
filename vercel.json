{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/bank-transfer-notify.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/writing/trial",
      "destination": "/writing/intro",
      "permanent": true
    },
    {
      "source": "/writing/trial/",
      "destination": "/writing/intro",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
