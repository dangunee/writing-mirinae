{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/bank-transfer-notify.ts": {
      "maxDuration": 30
    },
    "api/webhooks/stripe.ts": {
      "maxDuration": 30
    },
    "api/writing/trial-payment/create-checkout-session.ts": {
      "maxDuration": 30
    },
    "api/writing/trial-payment/payment-result.ts": {
      "maxDuration": 30
    },
    "api/writing/admin/trial-applications/index.ts": {
      "maxDuration": 30
    },
    "api/writing/admin/trial-applications/[id]/activate.ts": {
      "maxDuration": 30
    },
    "api/writing/admin/trial-applications/[id]/resend-access.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/writing/trial",
      "destination": "/writing/intro",
      "permanent": true
    },
    {
      "source": "/writing/trial/",
      "destination": "/writing/intro",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
